{
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#39FF14",
    "editor.selectionBackground": "#39FF1433", // The '33' makes it transparent green
    "editor.lineHighlightBackground": "#0cff1c11", // Subtle glow on the current line
    "terminal.foreground": "#39FF14",
    "terminal.background": "#000000",

    "editor.background": "#000000",
    // Activity Bar (The far left icons bar)
    "activityBar.background": "#070021",
    "activityBar.foreground": "#a20cff",
    "activityBar.inactiveForeground": "#070021",
    "activityBar.border": "#0cf4ff33",

    // Side Bar (The Explorer/Folders area)
    "sideBar.background": "#000000",
    "sideBar.foreground": "#39FF14",
    "sideBar.border": "#0cf4ff33",

    // Status Bar (The very bottom bar)
    "statusBar.background": "#000000",
    "statusBar.foreground": "#39FF14",
    "statusBar.border": "#0cffdb33",

    // Title Bar (The very top bar)
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#39FF14",

    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    
        // The main box background and foreground
    "quickInput.background": "#000000",
    "quickInput.foreground": "#39FF14",
    
    // The list items inside the palette
    "quickInputList.focusBackground": "#0cff1c33", // Glow when you highlight an item
    "quickInputList.focusForeground": "#39FF14",   // Text color when highlighted
    
    // The border around the whole palette
    "widget.border": "#39FF14",
    "contrastBorder": "#0cff3433", // Optional: adds a thin outline
    "editorBracketHighlight.foreground1": "#FF0000",
    "editorBracketHighlight.foreground2": "#FF0000",
    "editorBracketHighlight.unexpectedBracket.foreground": "#FF0000"

  },
    "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Functions",
        "scope": [
          "support.function",
          "entity.name.function",
          "meta.function-call" 
        ],
        "settings": {
          "foreground": "#00ff04",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Variables and Arguments",
        "scope": [
          "variable.other",
          "variable.parameter",
          "meta.function-call.arguments"
        ],
        "settings": {
          "foreground": "#128e43",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Strings",
        "scope": "string",
        "settings": {
          "foreground": "#05ae62"
        }
      },
      {
        "name": "Comments",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#007317f1",
          "fontStyle": "italic"
        }
      },
      {
        "name": "others",
        "scope": [
          "source.python",
          "variable.other.readwrite.python",
          "variable.other.assignment.python",
          "meta.function-call.arguments.python"
        ],
        "settings": {
          "foreground": "#9a1498",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Python Conditionals",
        "scope": [
          "keyword.control.conditional.python",
          "keyword.control.flow.python"
        ],
        "settings": {
          "foreground": "#ff9100"
        }
      },
      {
        "name": "Punctuation and Operators",
        "scope": [
          "punctuation",
          "punctuation.definition",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.section",
          "punctuation.bracket",
          "keyword.operator",
          "keyword.operator.assignment",
          "keyword.operator.arithmetic",
          "keyword.operator.comparison",
          "keyword.operator.logical"
        ],
        "settings": {
          "foreground": "#55ff00" // Pick a color that stands out against your black background
        }
      },
      {
        "name": "Numbers",
        "scope": [
          "constant.numeric"
        ],
        "settings": {
          "foreground": "#00ff26" 
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
}
