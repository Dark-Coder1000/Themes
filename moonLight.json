{
  "workbench.colorCustomizations": {
    "editor.background": "#070021",
    "editorCursor.foreground": "#0cffe3",
    "editor.selectionBackground": "#0cffe333",
    "editor.lineHighlightBackground": "#0cffe311",
    "terminal.foreground": "#0cffe3",
    "terminal.background": "#070021",

    // Activity Bar
    "activityBar.background": "#070021",
    "activityBar.foreground": "#a20cff",
    "activityBar.inactiveForeground": "#070021",
    "activityBar.border": "#0cf4ff33",

    // Side Bar
    "sideBar.background": "#070021",
    "sideBar.foreground": "#05e1bc",
    "sideBar.border": "#0cf4ff33",

    // Status Bar
    "statusBar.background": "#070021",
    "statusBar.foreground": "#0cffd2",
    "statusBar.border": "#0cffdb33",

    // Title Bar
    "titleBar.activeBackground": "#070021",
    "titleBar.activeForeground": "#0cffef",

    // Tabs
    "editorGroupHeader.tabsBackground": "#070021",
    "tab.activeBackground": "#070021",
    "tab.inactiveBackground": "#070021",
    
    // Quick Input / Palette
    "quickInput.background": "#070021",
    "quickInput.foreground": "#0cffe3",
    "quickInputList.focusBackground": "#0cffca33",
    "quickInputList.focusForeground": "#0cffba",
    
    // Borders
    "widget.border": "#0cffbe",
    "contrastBorder": "#0cffca33",

    // Brackets (Matching the Blue Function color)
    "editorBracketHighlight.foreground1": "#006aff",
    "editorBracketHighlight.foreground2": "#b23eff",
    "editorBracketHighlight.unexpectedBracket.foreground": "#ff2e2e"
  },

  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Functions",
        "scope": [
          "support.function",
          "entity.name.function",
          "meta.function-call" 
        ],
        "settings": {
          "foreground": "#006aff",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Variables and Arguments",
        "scope": [
          "variable.other",
          "variable.parameter",
          "meta.function-call.arguments"
        ],
        "settings": {
          "foreground": "#b23eff",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Strings",
        "scope": "string",
        "settings": {
          "foreground": "#fd0707"
        }
      },
      {
        "name": "Comments",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#00e1ffad",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Python Conditionals",
        "scope": [
          "keyword.control.conditional.python",
          "keyword.control.flow.python"
        ],
        "settings": {
          "foreground": "#0047c1"
        }
      },
      {
        "name": "Punctuation and Operators",
        "scope": [
          "punctuation",
          "punctuation.definition",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.section",
          "punctuation.bracket",
          "keyword.operator"
        ],
        "settings": {
          "foreground": "#0cffe3" 
        }
      },
      {
        "name": "Numbers",
        "scope": [
          "constant.numeric"
        ],
        "settings": {
          "foreground": "#ff2e2e" 
        }
      },
      {
        "name": "others",
        "scope": [
          "source.python",
          "variable.other.readwrite.python",
          "variable.other.assignment.python",
          "meta.function-call.arguments.python"
        ],
        "settings": {
          "foreground": "#FFC42E",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Imports",
        "scope": [
          "keyword.control.import",
          "keyword.control.from"  
        ],
        "settings": {
          "foreground": "#FF0000", // Change to your preferred color
          "fontStyle": "italic bold"
        }
      },
      {
        "name": "Definitions",
        "scope": [
            "storage.type.function", // This targets 'def'
            "storage.type.class"
        ],
        "settings": {
            "foreground": "#00ff51",
            "fontStyle": "bold"
        }
      },
      {
        "name": "Booleans",
        "scope": [
          "constant.language.boolean",
          "constant.language.python" // Specific for True/False in Python
        ],
        "settings": {
          "foreground": "#04ff00", // Matching your Mint Green data color
          "fontStyle": "bold"
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right"
}
