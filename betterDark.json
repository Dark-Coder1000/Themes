{
  "workbench.colorCustomizations": {
    "editor.background": "#000000",
    // Activity Bar (The far left icons bar)
    "activityBar.background": "#000000",
    "activityBar.foreground": "#ff0c0c",
    "activityBar.inactiveForeground": "#000000",
    "activityBar.border": "#0cf4ff33",

    // Side Bar (The Explorer/Folders area)
    "sideBar.background": "#000000",
    "sideBar.foreground": "#e10505",
    "sideBar.border": "#0cf4ff33",

    // Status Bar (The very bottom bar)
    "statusBar.background": "#000000",
    "statusBar.foreground": "#ff0c0c",
    "statusBar.border": "#ff0c0c33",

    // Title Bar (The very top bar)
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#ff0c0c",

    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#170303a7",
    
        // The main box background and foreground
    "quickInput.background": "#000000",
    "quickInput.foreground": "#ff0c0c",
    
    // The list items inside the palette
    "quickInputList.focusBackground": "#ff0c0c33", // Glow when you highlight an item
    "quickInputList.focusForeground": "#ff0c0c",   // Text color when highlighted
    
    // The border around the whole palette
    "widget.border": "#ff0c0c",
    "contrastBorder": "#ff0c0c33" // Optional: adds a thin outline

  },
    "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Functions",
        "scope": [
          "support.function",
          "entity.name.function",
          "meta.function-call" 
        ],
        "settings": {
          "foreground": "#ff0000",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Variables and Arguments",
        "scope": [
          "variable.other",
          "variable.parameter",
          "meta.function-call.arguments"
        ],
        "settings": {
          "foreground": "#ff3e3e",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Strings",
        "scope": "string",
        "settings": {
          "foreground": "#00ff9d"
        }
      },
      {
        "name": "Comments",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#0400ffad",
          "fontStyle": "italic"
        }
      },
      {
        "name": "others",
        "scope": [
          "source.python",
          "variable.other.readwrite.python",
          "variable.other.assignment.python",
          "meta.function-call.arguments.python"
        ],
        "settings": {
          "foreground": "#ff2e2e",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Python Conditionals",
        "scope": [
          "keyword.control.conditional.python",
          "keyword.control.flow.python"
        ],
        "settings": {
          "foreground": "#0047c1"
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
}
