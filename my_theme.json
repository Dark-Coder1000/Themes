{
  "workbench.colorCustomizations": {
    "editor.background": "#000000",
    "editorCursor.foreground": "#FFC42E",
    "editor.selectionBackground": "#FFC42E33",
    "editor.lineHighlightBackground": "#ffc42e11",
    "terminal.foreground": "#FFC42E",
    "terminal.background": "#000000",

    // Activity Bar
    "activityBar.background": "#261b00",
    "activityBar.foreground": "#a20cff",
    "activityBar.inactiveForeground": "#4b3700",
    "activityBar.border": "#ffc42e4c",

    // Side Bar
    "sideBar.background": "#000000",
    "sideBar.foreground": "#FFC42E",
    "sideBar.border": "#ffc42e4c",

    // Status Bar
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFC42E",
    "statusBar.border": "#ffc42e4c",

    // Title Bar
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#FFC42E",

    // Tabs
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    
    // Quick Input / Palette
    "quickInput.background": "#000000",
    "quickInput.foreground": "#FFC42E",
    "quickInputList.focusBackground": "#ffc42e4c",
    "quickInputList.focusForeground": "#FFC42E",
    
    // Borders
    "widget.border": "#FFC42E",
    "contrastBorder": "#ffc42e4c",

    // Bracket Pair Colorization (Red as requested)
    "editorBracketHighlight.foreground1": "#010bcb",
    "editorBracketHighlight.foreground2": "#010bcb",
    "editorBracketHighlight.unexpectedBracket.foreground": "#010bcb"
  },

  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Functions",
        "scope": [
          "support.function",
          "entity.name.function",
          "meta.function-call" 
        ],
        "settings": {
          "foreground": "#cb0101",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Variables and Arguments",
        "scope": [
          "variable.other",
          "variable.parameter",
          "meta.function-call.arguments"
        ],
        "settings": {
          "foreground": "#FFC42E",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Strings",
        "scope": "string",
        "settings": {
          "foreground": "#ff2eaf"
        }
      },
      {
        "name": "Comments",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#ffb7008b",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Python Conditionals",
        "scope": [
          "keyword.control.conditional.python",
          "keyword.control.flow.python"
        ],
        "settings": {
          "foreground": "#1937e3"
        }
      },
      {
        "name": "Punctuation and Operators",
        "scope": [
          "punctuation",
          "punctuation.definition",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.section",
          "punctuation.bracket",
          "keyword.operator"
        ],
        "settings": {
          "foreground": "#FFC42E" 
        }
      },
      {
        "name": "Numbers",
        "scope": [
          "constant.numeric"
        ],
        "settings": {
          "foreground": "#a20cff" 
        }
      },
      {
        "name": "others",
        "scope": [
          "source.python",
          "variable.other.readwrite.python",
          "variable.other.assignment.python",
          "meta.function-call.arguments.python"
        ],
        "settings": {
          "foreground": "#FFC42E",
          "fontStyle": "italic"
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right"
}
