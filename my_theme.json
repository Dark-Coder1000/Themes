{
  "workbench.colorCustomizations": {
    "editor.background": "#000000",
    // Activity Bar (The far left icons bar)
    "activityBar.background": "#261b00",
    "activityBar.foreground": "#a20cff",
    "activityBar.inactiveForeground": "#4b3700",
    "activityBar.border": "#ffc42e4c",

    // Side Bar (The Explorer/Folders area)
    "sideBar.background": "#000000",
    "sideBar.foreground": "#FFC42E",
    "sideBar.border": "#ffc42e4c",

    // Status Bar (The very bottom bar)
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFC42E",
    "statusBar.border": "#ffc42e4c",

    // Title Bar (The very top bar)
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#FFC42E",

    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#000000",
    
    // The main box background and foreground
    "quickInput.background": "#000000",
    "quickInput.foreground": "#FFC42E",
    
    // The list items inside the palette
    "quickInputList.focusBackground": "#ffc42e4c", // Glow when you highlight an item
    "quickInputList.focusForeground": "#FFC42E",   // Text color when highlighted
    
    // The border around the whole palette
    "widget.border": "#FFC42E",
    "contrastBorder": "#ffc42e4c" // Optional: adds a thin outline

  },
    "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Functions",
        "scope": [
          "support.function",
          "entity.name.function",
          "meta.function-call" 
        ],
        "settings": {
          "foreground": "#cb0101",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Variables and Arguments",
        "scope": [
          "variable.other",
          "variable.parameter",
          "meta.function-call.arguments"
        ],
        "settings": {
          "foreground": "#FFC42E",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Strings",
        "scope": "string",
        "settings": {
          "foreground": "#ff2eaf"
        }
      },
      {
        "name": "Comments",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#ffb7008b",
          "fontStyle": "italic"
        }
      },
      {
        "name": "others",
        "scope": [
          "source.python",
          "variable.other.readwrite.python",
          "variable.other.assignment.python",
          "meta.function-call.arguments.python"
        ],
        "settings": {
          "foreground": "#FFC42E",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Python Conditionals",
        "scope": [
          "keyword.control.conditional.python",
          "keyword.control.flow.python"
        ],
        "settings": {
          "foreground": "#1937e3"
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
}
